EBIRD_API_KEY=
ONLYBIRDS_LAT=
ONLYBIRDS_LON=
# Contact string sent in the Wikipedia User-Agent (email or URL). Optional, but
# recommended — Wikimedia throttles requests with vague UAs more aggressively.
ONLYBIRDS_CONTACT=

# Gemini API key for embeddings + LLM narration (https://aistudio.google.com/apikey).
GEMINI_API_KEY=

# Set to 1 to enable scraping eBird species pages for the Identification blurb.
# Off by default — review https://ebird.org/robots.txt before enabling.
ONLYBIRDS_EBIRD_SCRAPE=0
